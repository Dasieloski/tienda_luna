// Tienda Luna — POS offline-first, multi-tienda (tenant = storeId)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  /// App / runtime: pooler :6543 + ?pgbouncer=true (IPv4 en Shared pooler).
  url       = env("DATABASE_URL")
  /// Migraciones / `db push`: Session pooler Supabase :5432 (mismo host que transaction :6543), no db.*.co si no hay IPv6.
  directUrl = env("DIRECT_URL")
}

enum UserRole {
  ADMIN
  CASHIER
}

enum EventStatus {
  ACCEPTED
  REJECTED
  CORRECTED
}

enum OwnerName {
  OSMAR
  ALEX
}

enum PaymentCurrency {
  CUP
  USD
}

model Store {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /// Preferencias de widgets del dashboard (nivel 3)
  dashboardLayout Json?

  /// Cambio CUP por 1 USD (ej. 520). Usado para mostrar equivalencias en UI.
  usdRateCup Int? @default(250)

  users      User[]
  devices    Device[]
  products   Product[]
  customers  Customer[]
  events     Event[]
  sales      Sale[]
  salePayments SalePayment[]
  saleReturns  SaleReturn[]
  ownerSales OwnerSale[]
  suppliers  Supplier[]
  supplierDebtPayments SupplierDebtPayment[]
  supplierWithdrawals SupplierWithdrawal[]
  inventoryMovements InventoryMovement[]
  metricSnapshots MetricSnapshot[]
  cashClosingDays CashClosingDay[]
  cashClosingRevisions CashClosingRevision[]
  cashClosingNotes CashClosingNote[]
  cashClosingFindings CashClosingFinding[]
  auditLogs AuditLog[]
}

/// Nomenclador de proveedores por tienda (nombre único por tienda).
model Supplier {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name      String
  phone     String?
  notes     String?
  active    Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  debtPayments SupplierDebtPayment[]
  withdrawals SupplierWithdrawal[]

  @@unique([storeId, name])
  @@index([storeId, active])
}

model SupplierDebtPayment {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplierId String
  supplier   Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  amountCents Int
  paidAt     DateTime @default(now())
  method     String?
  note       String?
  actorUserId String

  @@index([storeId, supplierId, paidAt])
  @@index([storeId, paidAt])
}

model SupplierWithdrawal {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  supplierId  String
  supplier    Supplier @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  totalCostCents   Int @default(0)
  totalRetailCents Int @default(0)
  note        String?
  actorUserId String
  createdAt   DateTime @default(now())

  lines SupplierWithdrawalLine[]

  @@index([storeId, supplierId, createdAt])
  @@index([storeId, createdAt])
}

model SupplierWithdrawalLine {
  id            String   @id @default(cuid())
  withdrawalId  String
  withdrawal    SupplierWithdrawal @relation(fields: [withdrawalId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName   String?
  productSku    String?
  quantity      Int
  unitCostCents Int
  unitRetailCents Int
  subtotalCostCents Int
  subtotalRetailCents Int

  @@index([withdrawalId])
  @@index([productId])
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole
  storeId      String
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())
  /// 2FA TOTP (panel admin). Se guarda el secreto cifrado.
  totpEnabled  Boolean  @default(false)
  totpSecret   String?
  totpVerifiedAt DateTime?

  @@index([storeId])
}

/// Terminales POS: autenticación por token (hash), sin usuario humano
model Device {
  id         String    @id @default(cuid())
  storeId    String
  store      Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  label      String
  tokenHash  String    @unique
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())

  @@index([storeId])
}

model Product {
  id          String   @id @default(cuid())
  storeId     String
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  sku         String
  name        String
  /// PVP al público en CUP (céntimos)
  priceCents  Int      @default(0)
  /// PVP al público en USD (centavos de dólar, ej. 199 = US$1.99)
  priceUsdCents Int    @default(0)
  /// Unidades que trae una caja (referencia de compra / etiqueta)
  unitsPerBox Int      @default(1)
  /// Precio mayorista sugerido en CUP (céntimos); referencia en panel
  wholesaleCupCents Int?
  costCents   Int?
  /// Proveedor del nomenclador (preferido).
  supplierId   String?
  supplier     Supplier? @relation(fields: [supplierId], references: [id], onDelete: SetNull)
  /// Copia del nombre para compatibilidad / export; sincronizar con Supplier cuando hay supplierId.
  supplierName String?
  stockQty    Int      @default(0)
  lowStockAt  Int      @default(5)
  active      Boolean  @default(true)
  /// Borrado lógico: el registro se conserva para historial y líneas de venta.
  deletedAt   DateTime?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  saleLines SaleLine[]
  saleReturnLines SaleReturnLine[]
  ownerSaleLines OwnerSaleLine[]
  inventoryMovements InventoryMovement[]
  supplierWithdrawalLines SupplierWithdrawalLine[]

  @@unique([storeId, sku])
  @@index([storeId])
  @@index([storeId, deletedAt])
  @@index([supplierId])
}

/// Kardex: entradas/salidas y ajustes de stock por producto.
model InventoryMovement {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  productId String?
  product   Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  /// Snapshot para conservar historial si el producto se borra
  productName String?
  productSku  String?

  /// Diferencia aplicada al stock (positivo = entrada, negativo = salida)
  delta     Int
  beforeQty Int
  afterQty  Int

  /// Motivo (ej. MANUAL_ADJUST, SALE_COMPLETED, STOCK_DECREASED)
  reason    String

  /// Quién lo hizo (USER o DEVICE) y su id (userId o deviceId)
  actorType String
  actorId   String

  /// Si proviene de un evento del sync, se enlaza aquí.
  eventId   String?
  event     Event?    @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([storeId, productId, createdAt])
  @@index([storeId, actorType, actorId, createdAt])
  @@index([storeId, eventId])
}

model Customer {
  id         String   @id @default(cuid())
  storeId    String
  store      Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  name       String?
  phone      String?
  email      String?
  externalId String?
  createdAt  DateTime @default(now())

  sales Sale[]

  @@index([storeId])
  @@index([storeId, phone])
}

/// Libro mayor de eventos (fuente de verdad para auditoría / reconstrucción)
model Event {
  id                  String      @id @default(cuid())
  /// Id enviado por el cliente (UUID); idempotencia por tienda
  clientEventId       String
  type                String
  payload             Json
  payloadHash         String
  storeId             String
  store               Store       @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId            String
  clientTimestamp     BigInt
  serverTimestamp     DateTime    @default(now())
  status              EventStatus
  isFraud             Boolean     @default(false)
  fraudReason         String?
  correctionNote      String?
  /// Agrupa eventos de una misma venta offline (payload.saleId)
  relatedClientSaleId String?

  inventoryMovements InventoryMovement[]
  salePayments SalePayment[]
  saleReturns  SaleReturn[]

  @@unique([storeId, clientEventId])
  @@index([storeId, serverTimestamp])
  @@index([storeId, deviceId])
  @@index([storeId, type])
  @@index([storeId, deviceId, clientTimestamp, payloadHash])
}

/// Proyección de ventas aceptadas (consultas rápidas; reconstruible desde Event)
model Sale {
  id           String    @id @default(cuid())
  storeId      String
  store        Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  deviceId     String
  /// Quién registró la venta (cajero/admin). Texto libre (email o nombre).
  soldBy       String?
  clientSaleId String?
  customerId   String?
  customer     Customer? @relation(fields: [customerId], references: [id])
  totalCents   Int       @default(0)
  /// Total pagado acumulado (CUP céntimos). Para fiado/pagos parciales.
  paidTotalCents Int     @default(0)
  /// Balance = totalCents - paidTotalCents. Puede ser negativo si hay sobrepago/nota de crédito.
  balanceCents Int       @default(0)
  /// Estado de pago: PAID | PARTIAL | CREDIT_OPEN | OVERPAID (string para compatibilidad)
  paymentStatus String   @default("PAID")
  /// Marca si fue editada después de completada.
  editedAt    DateTime?
  revisionCount Int      @default(0)
  status       String    @default("COMPLETED")
  completedAt  DateTime  @default(now())
  lines        SaleLine[]
  payments     SalePayment[]
  returns      SaleReturn[]

  @@index([storeId, completedAt])
  @@index([storeId, deviceId])
  @@index([storeId, clientSaleId])
}

model SaleLine {
  id             String  @id @default(cuid())
  saleId         String
  sale           Sale    @relation(fields: [saleId], references: [id], onDelete: Cascade)
  productId      String?
  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  /// Snapshot para conservar historial si el producto se borra
  productName    String?
  productSku     String?
  quantity       Int
  unitPriceCents Int
  subtotalCents  Int
  /// Snapshot del costo proveedor en el momento de la venta (si existe).
  unitCostCents  Int?
  subtotalCostCents Int?

  @@index([productId])
}

model SalePayment {
  id             String   @id @default(cuid())
  storeId        String
  store          Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  saleId         String
  sale           Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  /// Importe final en CUP (céntimos) que afecta contabilidad/cuadre.
  amountCupCents Int

  /// Moneda original capturada (CUP o USD). Si USD, `originalAmount` se expresa en centavos USD.
  currency       PaymentCurrency @default(CUP)
  originalAmount Int?
  usdRateCup     Int?

  /// Método/canal (cash, transfer, usd_cash, etc.)
  method         String

  /// Momento del pago (importante para cuadre por día si el abono ocurre otro día).
  paidAt         DateTime @default(now())

  /// Si proviene de un evento, se enlaza para trazabilidad.
  eventId        String?
  event          Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  createdAt      DateTime @default(now())

  @@index([storeId, paidAt])
  @@index([storeId, saleId, paidAt])
  @@index([storeId, method, paidAt])
  @@index([eventId])
}

model SaleReturn {
  id            String   @id @default(cuid())
  storeId       String
  store         Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  saleId        String
  sale          Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)

  /// Importe en CUP (céntimos) del ajuste (negativo o positivo según convención; aquí guardamos negativo).
  amountCupCents Int
  reason        String?
  returnedAt    DateTime @default(now())

  eventId       String?
  event         Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)

  lines         SaleReturnLine[]

  @@index([storeId, returnedAt])
  @@index([storeId, saleId, returnedAt])
  @@index([eventId])
}

model SaleReturnLine {
  id            String   @id @default(cuid())
  saleReturnId  String
  saleReturn    SaleReturn @relation(fields: [saleReturnId], references: [id], onDelete: Cascade)
  productId     String?
  product       Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  productName   String?
  productSku    String?
  quantity      Int
  unitPriceCents Int
  subtotalCents  Int

  @@index([saleReturnId])
  @@index([productId])
}

/// Consumo de los dueños: descuenta stock, pero NO cuenta como ingreso/ganancia.
model OwnerSale {
  id        String    @id @default(cuid())
  storeId   String
  store     Store     @relation(fields: [storeId], references: [id], onDelete: Cascade)
  owner     OwnerName
  /// Deuda calculada a precio de costo proveedor (snapshot en líneas).
  totalCents Int      @default(0)
  status    OwnerSaleStatus @default(PENDING_PAYMENT)
  createdAt DateTime  @default(now())
  paidAt    DateTime?
  /// Venta normal creada al pagar (para cuadre/analítica).
  paidSaleId String?

  lines OwnerSaleLine[]

  @@index([storeId, createdAt])
  @@index([storeId, owner, createdAt])
  @@index([storeId, status, createdAt])
  @@index([storeId, paidAt])
}

model OwnerSaleLine {
  id          String    @id @default(cuid())
  ownerSaleId String
  ownerSale   OwnerSale @relation(fields: [ownerSaleId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product?   @relation(fields: [productId], references: [id], onDelete: SetNull)
  /// Snapshot para conservar historial si el producto se borra
  productName String?
  productSku  String?
  quantity    Int
  /// Snapshot de costo proveedor en el momento del consumo.
  unitCostCents Int      @default(0)
  subtotalCents  Int

  @@index([ownerSaleId])
  @@index([productId])
}

enum OwnerSaleStatus {
  PENDING_PAYMENT
  PAID
}

/// Snapshots diarios agregados (para analítica histórica rápida).
model MetricSnapshot {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  /// Día (UTC) representado por este snapshot (convención: 00:00:00.000Z).
  day       DateTime

  revenueCents   Int      @default(0)
  saleCount      Int      @default(0)
  ticketAvgCents Int      @default(0)

  /// Margen estimado en CUP (solo líneas con coste definido).
  marginCents    Int      @default(0)
  marginPct      Float?
  linesWithCost  Int      @default(0)
  linesWithoutCost Int    @default(0)

  /// Mezcla de pagos (por método), agregada por día.
  paymentMix Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([storeId, day])
  @@index([storeId, day])
}

/// Estado diario del cuadre de caja + auditoría.
model CashClosingDay {
  id       String @id @default(cuid())
  storeId  String
  store    Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)

  /// Día local de la tienda en formato YYYY-MM-DD (evita ambigüedad de TZ).
  dayYmd   String

  status   CashClosingStatus

  /// Valores contados (lo que hay físicamente).
  cashCountedCents        Int @default(0)
  transferCountedCents    Int @default(0)
  usdChannelCountedCents  Int @default(0)

  /// Valores esperados (snapshot al momento de validar).
  cashExpectedCents       Int @default(0)
  transferExpectedCents   Int @default(0)
  usdChannelExpectedCents Int @default(0)

  /// Diferencia total (contado - esperado) guardada para consultas rápidas.
  diffTotalCents          Int @default(0)

  /// Categoría principal (obligatoria si status=INCORRECT).
  category CashClosingCategory?

  /// Observación actual (obligatoria si status=INCORRECT).
  observation String?

  /// Quién validó/actualizó por última vez.
  validatedByUserId String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  notes     CashClosingNote[]
  revisions CashClosingRevision[]
  findings  CashClosingFinding[]

  @@unique([storeId, dayYmd])
  @@index([storeId, dayYmd])
  @@index([storeId, status, dayYmd])
}

/// Historial inmutable de cambios del cuadre.
model CashClosingRevision {
  id            String @id @default(cuid())
  storeId       String
  store         Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashClosingDayId String
  day           CashClosingDay @relation(fields: [cashClosingDayId], references: [id], onDelete: Cascade)

  actorUserId   String
  action        String // CREATE | UPDATE | SYSTEM_RECALC
  before        Json?
  after         Json?
  meta          Json?
  createdAt     DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([cashClosingDayId, createdAt])
}

/// Notas y seguimiento (historial por día).
model CashClosingNote {
  id            String @id @default(cuid())
  storeId       String
  store         Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashClosingDayId String
  day           CashClosingDay @relation(fields: [cashClosingDayId], references: [id], onDelete: Cascade)

  category      CashClosingCategory?
  message       String
  actorUserId   String
  createdAt     DateTime @default(now())

  @@index([cashClosingDayId, createdAt])
  @@index([storeId, createdAt])
}

/// Hallazgos detectados automáticamente (y sus sugerencias).
model CashClosingFinding {
  id            String @id @default(cuid())
  storeId       String
  store         Store  @relation(fields: [storeId], references: [id], onDelete: Cascade)
  cashClosingDayId String
  day           CashClosingDay @relation(fields: [cashClosingDayId], references: [id], onDelete: Cascade)

  code          String // SYNC_LAG | POSSIBLE_DUPLICATE | MISSING_SALE | TZ_DRIFT | MANUAL_ADJUST
  severity      String // INFO | WARN | ERROR
  title         String
  detail        String
  suggestion    String?
  evidence      Json?

  createdAt DateTime @default(now())

  @@index([cashClosingDayId, createdAt])
  @@index([storeId, createdAt])
  @@index([storeId, code, createdAt])
}

enum CashClosingStatus {
  CORRECT
  INCORRECT
}

enum CashClosingCategory {
  CASH_SHORT
  CASH_OVER
  HUMAN_ERROR
  SYSTEM_BUG
  DESYNC
  TZ_DRIFT
  OTHER
}

/// Auditoría de acciones sensibles (cambios de producto, stock, ajustes, configuraciones).
model AuditLog {
  id        String   @id @default(cuid())
  storeId   String
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  actorType String   /// USER | DEVICE
  actorId   String

  action    String   /// e.g. PRODUCT_UPDATE, PRODUCT_ARCHIVE, EXCHANGE_RATE_UPDATE
  entityType String  /// e.g. Product, Store, InventoryMovement
  entityId  String?

  before    Json?
  after     Json?
  meta      Json?

  createdAt DateTime @default(now())

  @@index([storeId, createdAt])
  @@index([storeId, action, createdAt])
  @@index([storeId, entityType, entityId])
}
