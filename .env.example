# --- Local (Docker): npm run db:up ---
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/postgres"
DIRECT_URL="postgresql://postgres:postgres@127.0.0.1:5432/postgres"

# --- Supabase + Prisma (modal Connect → ORM) ---
# Puedes poner solo estas dos en .env.local; `scripts/prisma-with-env.cjs` carga .env y .env.local (local pisa .env).
# Sustituye [YOUR-PASSWORD] y el host del pooler por el que te muestra TU proyecto (región).
# DATABASE_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:6543/postgres?pgbouncer=true"
# DIRECT_URL="postgresql://postgres.[PROJECT_REF]:[YOUR-PASSWORD]@aws-1-us-west-2.pooler.supabase.com:5432/postgres"
# Opcional recomendado: en DATABASE_URL añade &connection_limit=1&sslmode=require ; en DIRECT_URL añade ?sslmode=require
# La URI directa postgres@db.*.supabase.co:5432 del panel suele ser solo IPv6; para migraciones usa DIRECT_URL = session pooler :5432.
# https://supabase.com/docs/guides/database/prisma
# P5010: quita DATABASE_URL=prisma+... de variables de entorno del sistema.
NEXT_PUBLIC_SUPABASE_URL="https://TU_REF.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="sb_publishable_..."

# Secreto para JWT de usuarios y dispositivos (mínimo 16 caracteres)
JWT_SECRET="cambiar-por-un-secreto-largo-y-aleatorio"

# Opcional: anular credenciales estáticas del admin (por defecto ver lib/static-admin-auth.ts)
# STATIC_ADMIN_EMAIL=
# STATIC_ADMIN_PASSWORD=
# ID de tienda para el JWT del admin estático (si vacío, se intenta la primera Store en BD)
# STATIC_ADMIN_STORE_ID=

# 1 = no consultar la BD al hacer login (útil si Prisma/Supabase falla o tarda)
# STATIC_ADMIN_SKIP_DB=1
